# ── Server-only secrets (Next.js API routes + Python scrapers) ──
# Supabase project URL (e.g. https://abcdefgh.supabase.co)
SUPABASE_URL=
# Supabase SERVICE ROLE key — bypasses RLS. Used by Python scrapers ONLY.
# Never expose this to the browser.
SUPABASE_SERVICE_KEY=
# Anthropic API key — used by the Python scorer (and any server-side scoring).
ANTHROPIC_API_KEY=
# Google Maps Geocoding API key (billing-enabled). Used by the Python geocoding
# pass AND the Next.js /api/profile route to geocode the home base. Server-only.
GOOGLE_MAPS_API_KEY=
# Email of the job-seeker whose profile Claude should score against. Optional —
# if unset, the scraper scores against the most-complete profile.
CLASSQUEST_USER_EMAIL=

# ── Public client values (safe to expose to the browser) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
