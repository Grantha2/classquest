# ── Server-only secrets (Next.js API routes + Python scrapers) ──
# Supabase project URL (e.g. https://abcdefgh.supabase.co)
SUPABASE_URL=
# Supabase SERVICE ROLE key — bypasses RLS. Used by Python scrapers ONLY.
# Never expose this to the browser.
SUPABASE_SERVICE_KEY=
# Anthropic API key — used by the Python scorer (and any server-side scoring).
ANTHROPIC_API_KEY=

# ── Public client values (safe to expose to the browser) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
