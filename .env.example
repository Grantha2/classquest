# ── Server-only secrets (Next.js API routes + Python scrapers) ──
# Supabase project URL (e.g. https://abcdefgh.supabase.co)
SUPABASE_URL=
# Supabase SERVICE ROLE key — bypasses RLS. Used by Python scrapers ONLY.
# Never expose this to the browser.
SUPABASE_SERVICE_KEY=
# Anthropic API key — used by the Python scorer (and any server-side scoring).
ANTHROPIC_API_KEY=
# Google Maps Geocoding API key (billing-enabled). Used by the Python geocoding
# pass AND the Next.js /api/profile route to geocode the home base. Server-only.
GOOGLE_MAPS_API_KEY=
# Email of the job-seeker whose profile Claude should score against. Optional —
# if unset, the scraper scores against the most-complete profile. Also the
# recipient of the daily email digest.
CLASSQUEST_USER_EMAIL=

# ── Daily email digest (scrape cron; all optional — digest skips if unset) ──
# Resend API key (resend.com). Sender defaults to the Resend test address,
# which only delivers to the account owner — set RESEND_FROM after verifying
# a domain.
RESEND_API_KEY=
RESEND_FROM=
# Public URL of the deployed app; adds an "open dashboard" link to the digest.
CLASSQUEST_APP_URL=

# ── Score refresh on profile save (Next.js /api/profile; optional) ──
# Fine-grained GitHub token with Actions:write on this repo. When set, saving
# the profile fires a workflow_dispatch on scrape.yml so scores re-personalize
# within ~a minute instead of at the next cron run.
GITHUB_DISPATCH_TOKEN=
# e.g. Grantha2/classquest
GITHUB_REPO=

# ── Public client values (safe to expose to the browser) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
